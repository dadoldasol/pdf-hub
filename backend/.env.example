APP_NAME=PDF Knowledge Hub
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pdf_hub

PDF_STORAGE_DIR=./storage/pdfs

OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=
ENTITY_VALIDATION_MODEL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536
ENABLE_LLM_ENTITY_VALIDATION=false
ENTITY_VALIDATION_BATCH_SIZE=20
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
